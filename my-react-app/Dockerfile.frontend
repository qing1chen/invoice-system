# ============================================================
#  my-react-app 前端 Dockerfile
#  阶段1: Node.js 构建  →  阶段2: Nginx 托管
# ============================================================

# ── 阶段 1: 构建 ──────────────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /app

COPY package.json package-lock.json* yarn.lock* ./
RUN npm install

COPY . .

# 接收 .env → docker-compose args → Vite 环境变量
ARG VITE_LLM_API_KEY
ARG VITE_LLM_BASE_URL
ARG VITE_LLM_MODEL
ARG VITE_NAME_LIST
ENV VITE_LLM_API_KEY=$VITE_LLM_API_KEY
ENV VITE_LLM_BASE_URL=$VITE_LLM_BASE_URL
ENV VITE_LLM_MODEL=$VITE_LLM_MODEL
ENV VITE_NAME_LIST=$VITE_NAME_LIST

RUN npm run build

# ── 阶段 2: Nginx ─────────────────────────────────────────
FROM nginx:alpine
RUN rm /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
