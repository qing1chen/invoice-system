# ============================================================
#  环境变量配置
#  使用方法: cp .env.example .env  然后填写真实值
# ============================================================

# ── 必填 ──────────────────────────────────────────────────

# ---- LLM API (SiliconFlow / OpenAI 兼容接口) ----
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL_NAME=deepseek-ai/DeepSeek-V3
LLM_TEMPERATURE=0.1

# ---- 浏览器自动化专用 LLM（千问 VL，支持视觉理解）----
BROWSER_MODEL_NAME=Qwen/Qwen3-VL-32B-Instruct
BROWSER_HEADLESS=false
BROWSER_USE_VISION=true

# ---- 百度 OCR API ----
# 申请地址: https://console.bce.baidu.com/ai/#/ai/ocr/overview/index
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key

# ── LLM 调用限流（控制费用）─────────────────────
LLM_CALL_INTERVAL=5.0
MAX_LLM_CALLS=30

# ── SDU 登录凭据 ─────────────────────────────────
SDU_USERNAME=your_student_id
SDU_PASSWORD=your_password

# ── 认证模式 ─────────────────────────────────────
# manual      = 手动登录优先（推荐 Docker 使用，通过 noVNC 操作浏览器）
# auto        = 自动登录优先（Playwright fill + click）
# cookie_only = 仅用 Cookie（不做任何登录尝试）
AUTH_MODE=auto

# 手动登录超时（秒），超时后降级为自动登录
MANUAL_LOGIN_TIMEOUT=300

# Cookie 文件路径
COOKIE_FILE=data/cookies.json

# ── Docker 有头浏览器 ────────────────────────────
# Xvfb 虚拟显示（docker-entrypoint.sh 自动设置）
DISPLAY=:99

# ── 课题组成员名单（后端 config.py / 前端 index.js 共用）──
# 用英文逗号分隔，前后不要加空格；前端通过 docker-compose 的 build args 注入
NAME_LIST=张三
BATCH_SIZE=10
