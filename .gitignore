# ═════════════════════════════════════════════
#  Invoice System · Monorepo .gitignore
# ═════════════════════════════════════════════

# ─── 敏感配置(绝对不能上传) ─────────────────
.env
.env.local
.env.*.local
**/.env
!**/.env.example
*.pem
*.key

# Cookie / SSO 登录凭证
cookies.json
**/cookies.json
**/cookies/
invoice-toolkit/data/cookies.json

# ─── Python (invoice-toolkit/) ──────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# 虚拟环境
venv/
.venv/
env/
ENV/

# ─── 项目数据 (invoice-toolkit/) ────────────
# 用户私人数据(发票原件、报销明细等)
invoice-toolkit/data/课题组成员文件/
invoice-toolkit/data/*.xlsx
!invoice-toolkit/data/*.example.xlsx

# 生成的输出
invoice-toolkit/output/
invoice-toolkit/cache/

# 数据库
*.db
*.db-journal
*.sqlite
*.sqlite3

# RAG 向量索引
**/rag_index/
*.faiss
*.pkl

# 日志
*.log
logs/

# ─── Node / 前端 (frontend/) ────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── IDE ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── 模型 / HuggingFace 缓存 ────────────────
.cache/
**/transformers_cache/

# ─── 浏览器自动化产物 ──────────────────────
screenshots/
browser_session/
playwright-report/
test-results/
